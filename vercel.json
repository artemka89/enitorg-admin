{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://enitorg.ru/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://images.enitorg.ru/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/((?!api/|storage/).*)",
      "destination": "/index.html",
      "permanent": false
    }
  ]
}
